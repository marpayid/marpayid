
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Informasi profil pengguna MarPay.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "photoURL": { "type": "string" },
        "accountStatus": { "type": "string", "enum": ["active", "suspended"] },
        "role": { "type": "string", "enum": ["customer", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "email", "phone"]
    },
    "Address": {
      "title": "Address",
      "description": "Data alamat pengiriman pengguna.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "province": { "type": "string" },
        "city": { "type": "string" },
        "district": { "type": "string" },
        "fullAddress": { "type": "string" },
        "notes": { "type": "string" },
        "isPrimary": { "type": "boolean" }
      }
    },
    "Order": {
      "title": "Order",
      "description": "Data transaksi pesanan pelanggan.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "customerName": { "type": "string" },
        "customerEmail": { "type": "string" },
        "customerPhone": { "type": "string" },
        "items": { "type": "array" },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["Menunggu Pembayaran", "Pembayaran Diterima", "Diproses", "Dikirim", "Selesai", "Dibatalkan"] },
        "courier": { "type": "string" },
        "trackingNumber": { "type": "string" },
        "shippingAddress": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["email"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "Koleksi data profil pengguna."
    },
    "/users/{userId}/addresses/{addressId}": {
      "schema": { "$ref": "#/entities/Address" },
      "description": "Sub-koleksi alamat pengiriman pengguna."
    },
    "/orders/{orderId}": {
      "schema": { "$ref": "#/entities/Order" },
      "description": "Koleksi transaksi pesanan seluruh pelanggan (Admin View)."
    }
  }
}
