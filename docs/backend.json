
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Informasi profil pengguna MarPay.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "photoURL": { "type": "string" },
        "accountStatus": { "type": "string", "enum": ["active", "suspended"] },
        "role": { "type": "string", "enum": ["customer", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "email", "phone"]
    },
    "Address": {
      "title": "Address",
      "description": "Data alamat pengiriman pengguna.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "province": { "type": "string" },
        "city": { "type": "string" },
        "district": { "type": "string" },
        "fullAddress": { "type": "string" },
        "notes": { "type": "string" },
        "isPrimary": { "type": "boolean" }
      }
    },
    "Order": {
      "title": "Order",
      "description": "Data transaksi pesanan pelanggan.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "customerName": { "type": "string" },
        "customerEmail": { "type": "string" },
        "customerPhone": { "type": "string" },
        "items": { "type": "array" },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["Menunggu Pembayaran", "Pembayaran Diterima", "Diproses", "Dikirim", "Selesai", "Dibatalkan"] },
        "courier": { "type": "string" },
        "trackingNumber": { "type": "string" },
        "shippingAddress": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "NotificationToken": {
      "title": "NotificationToken",
      "description": "Token FCM untuk pengiriman notifikasi push.",
      "type": "object",
      "properties": {
        "token": { "type": "string" },
        "userId": { "type": "string" },
        "platform": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["token"]
    },
    "Product": {
      "title": "Product",
      "description": "Data produk yang dijual di MarPay.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "number" },
        "hargaSupplier": { "type": "number" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "image": { "type": "string" },
        "stock": { "type": "string" },
        "rating": { "type": "number" },
        "sold": { "type": "number" },
        "discount": { "type": "string" },
        "isFlashSale": { "type": "boolean" },
        "tag": { "type": "string" },
        "type": { "type": "string", "enum": ["physical", "digital"] },
        "shippingFee": { "type": "number" },
        "variants": { "type": "array", "items": { "type": "string" } },
        "colors": { "type": "array", "items": { "type": "string" } },
        "gender": { "type": "string", "enum": ["male", "female", "unisex"] },
        "brand": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "category"]
    }
  },
  "auth": {
    "providers": ["email"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "Koleksi data profil pengguna."
    },
    "/users/{userId}/addresses/{addressId}": {
      "schema": { "$ref": "#/entities/Address" },
      "description": "Sub-koleksi alamat pengiriman pengguna."
    },
    "/orders/{orderId}": {
      "schema": { "$ref": "#/entities/Order" },
      "description": "Koleksi transaksi pesanan seluruh pelanggan (Admin View)."
    },
    "/notification_tokens/{tokenId}": {
      "schema": { "$ref": "#/entities/NotificationToken" },
      "description": "Koleksi token notifikasi perangkat pengguna untuk pengiriman push notification."
    },
    "/products/{productId}": {
      "schema": { "$ref": "#/entities/Product" },
      "description": "Koleksi data produk marketplace."
    }
  }
}
